{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "recall",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "recall",
      "database_id": "a98140ab-bf97-4aea-89af-ede9768cdd94"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "recall-photos"
    }
  ]
}
